# ===================================
# BoatAI 環境変数設定
# ===================================
# このファイルを `.env.local` にコピーして使用してください
# cp .env.example .env.local

# -----------------------------------
# Supabase（必須）
# -----------------------------------
# Supabase Dashboard > Settings > API から取得
SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...

# 書き込み作業時のみ（通常は設定不要）
# Service Role Keyは管理者のみ使用
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------
# Google Analytics（オプション）
# -----------------------------------
# GA4のプロパティから取得
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------
# Linear（オプション）
# -----------------------------------
# Linear > Settings > API から取得
# 詳細は docs/setup/linear-setup.md を参照
LINEAR_API_KEY=lin_api_xxxxx
LINEAR_TEAM_ID=

# -----------------------------------
# SendGrid（オプション）
# -----------------------------------
# メール通知に使用
# SENDGRID_API_KEY=

# -----------------------------------
# Google Sheets（オプション）
# -----------------------------------
# データエクスポートに使用
# 詳細は docs/setup/automation-setup.md を参照
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
