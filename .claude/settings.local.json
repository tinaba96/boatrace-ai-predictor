{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(node:*)",
      "Bash(npm run:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(curl:*)",
      "Bash(vercel:*)",
      "Bash(gh:*)",
      "Bash(timeout:*)",
      "Bash(sleep:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(mv:*)",
      "WebFetch(domain:www.boatrace.jp)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:boat-ai.jp)",
      "WebSearch",
      "Skill(collect-stats)",
      "Skill(analyze-venue)",
      "WebFetch(domain:github.com)",
      "Bash(source .env.local)",
      "Bash(npx vercel:*)",
      "Bash(sips:*)",
      "Bash(xargs sed:*)",
      "Bash(xargs:*)",
      "WebFetch(domain:www.boat-ai.jp)",
      "Bash(pkill:*)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:kyoteibiyori.com)",
      "WebFetch(domain:alpedeveroski.com)",
      "WebFetch(domain:www.eurorvvv.org)",
      "WebFetch(domain:zenn.dev)",
      "Bash(python3:*)",
      "Bash(npm install:*)",
      "Read(//tmp/**)",
      "Bash(gh pr:*)",
      "mcp__linear__linear_search_issues_by_identifier",
      "Bash(\\\\\".is-w495\\\\\")",
      "mcp__linear__linear_search_issues",
      "mcp__linear__linear_get_teams",
      "mcp__linear__linear_create_issue",
      "mcp__linear__linear_bulk_update_issues",
      "mcp__linear__linear_create_comment",
      "Bash(kill %1)",
      "Bash(kill 77450)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r /:*)"
    ],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command=$(cat | jq -r '.tool_input.command' 2>/dev/null); if echo \"$command\" | grep -qE '(rm -rf /|DROP DATABASE|TRUNCATE)'; then echo 'BLOCKED: Dangerous command detected' >&2; exit 2; fi; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(cat | jq -r '.tool_input.file_path' 2>/dev/null); if [[ \"$file\" == *.js ]] || [[ \"$file\" == *.jsx ]]; then npx prettier --write \"$file\" 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  }
}
