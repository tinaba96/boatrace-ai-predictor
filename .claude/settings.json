{
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(npm run:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(gh:*)",
      "Bash(vercel:*)",
      "Bash(curl:*)",
      "WebFetch(domain:www.boatrace.jp)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "Skill(collect-stats)",
      "Skill(analyze-venue)",
      "Skill(daily-report)",
      "Skill(deploy-preview)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r /:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(cat | jq -r '.tool_input.file_path' 2>/dev/null); if [[ \"$file\" == *.js ]] || [[ \"$file\" == *.jsx ]]; then npx prettier --write \"$file\" 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  }
}
